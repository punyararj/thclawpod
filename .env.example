# Copy to .env and fill in values. docker-compose reads this automatically.

# Required: base URL of the THClaw agent server
TH_CLAW_URL=http://192.168.1.100:8000

# Optional: bearer token for the THClaw agent server
TH_CLAW_TOKEN=

# Optional: require this bearer token on incoming /chat requests
CLAWPOD_API_TOKEN=

# Optional overrides
#CLAWPOD_PORT=7001
#CLAWPOD_LOG_LEVEL=INFO
#CLAWPOD_AGENT=main
#CLAWPOD_TIMEOUT=60
#CLAWPOD_SESSION_PREFIX=homepod
#TH_CLAW_HOME=.
